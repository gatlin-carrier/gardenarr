# Default provider fallback keys — only the key for your active provider is needed.
# You can also configure the provider and key via the in-app Settings UI,
# in which case these env vars are not required.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_ai_key_here
# Ollama requires no key — just set the base URL in Settings if not running on localhost:11434
